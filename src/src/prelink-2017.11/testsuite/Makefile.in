	PRELINK="$(PRELINK_PROG) -c ./prelink.conf -C ./prelink.cache --ld-library-path=. --dynamic-linker=`echo ./ld*.so.*[0-9]`" \
	PRELINK_RTLD="$(PRELINK_RTLD)" \
	BUILD_CC="$(BUILD_CC)" \
	CC="$(CC_FOR_TARGET) $(LINKOPTS)" CCLINK="$(CC_FOR_TARGET) -Wl,--dynamic-linker=`echo ./ld*.so.*[0-9]`" \
