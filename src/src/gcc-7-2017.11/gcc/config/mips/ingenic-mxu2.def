/* Define a MXU2 MIPS_BUILTIN_DIRECT function __builtin_mxu2_<INSN>
   for instruction CODE_FOR_mxu2_<INSN>.  FUNCTION_TYPE is a
   builtin_description field.  */
#define MXU2_BUILTIN(INSN, FUNCTION_TYPE)				\
    { CODE_FOR_mxu2_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu2_" #INSN,  MIPS_BUILTIN_DIRECT,			\
    FUNCTION_TYPE, mips_builtin_avail_mxu2 }

/* Define a MXU2 MIPS_BUILTIN_DIRECT_NO_TARGET function __builtin_mxu2_<INSN>
   for instruction CODE_FOR_mxu2_<INSN>.  FUNCTION_TYPE is a
   builtin_description field.  */
#define MXU2_NO_TARGET_BUILTIN(INSN, FUNCTION_TYPE)			\
    { CODE_FOR_mxu2_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu2_" #INSN,  MIPS_BUILTIN_DIRECT_NO_TARGET,		\
    FUNCTION_TYPE, mips_builtin_avail_mxu2 }

