/* Define a MXU3 MIPS_BUILTIN_DIRECT function __builtin_mxu3_<INSN>
   for instruction CODE_FOR_mxu3_<INSN>.  FUNCTION_TYPE is a
   builtin_description field.  */
#define MXU3_BUILTIN(INSN, FUNCTION_TYPE)				\
    { CODE_FOR_mxu3_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu3_" #INSN,  MIPS_BUILTIN_DIRECT,			\
    FUNCTION_TYPE, mips_builtin_avail_mxu3 }

/* Define a MXU3 MIPS_BUILTIN_DIRECT_NO_TARGET function __builtin_mxu3_<INSN>
   for instruction CODE_FOR_mxu3_<INSN>.  FUNCTION_TYPE is a
   builtin_description field.  */
#define MXU3_NO_TARGET_BUILTIN(INSN, FUNCTION_TYPE)			\
    { CODE_FOR_mxu3_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu3_" #INSN,  MIPS_BUILTIN_DIRECT_NO_TARGET,		\
    FUNCTION_TYPE, mips_builtin_avail_mxu3 }

/* Define a MXU3 Subset only MXU3*/
#define MXU3_ONLY_BUILTIN(INSN, FUNCTION_TYPE)				\
    { CODE_FOR_mxu3_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu3_" #INSN,  MIPS_BUILTIN_DIRECT,			\
    FUNCTION_TYPE, mips_builtin_avail_mxu3_only }

#define MXU3_1_ONLY_TARGET_BUILTIN(INSN, FUNCTION_TYPE)				\
    { CODE_FOR_mxu3_ ## INSN, MIPS_FP_COND_f,				\
    "__builtin_mxu3_" #INSN,  MIPS_BUILTIN_DIRECT,			\
    FUNCTION_TYPE, mips_builtin_avail_mxu3_only }


