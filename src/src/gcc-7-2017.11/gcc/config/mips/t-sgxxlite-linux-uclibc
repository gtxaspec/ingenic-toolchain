MULTILIB_OPTIONS = muclibc/mglibc msoft-float/mfp32
MULTILIB_DIRNAMES = uclibc glibc
MULTILIB_DIRNAMES += soft-float fp32
MULTILIB_MATCHES = EL=mel EB=meb mfp32=mfpxx

MULTILIB_OSDIRNAMES  = muclibc=!uclibc
MULTILIB_OSDIRNAMES += mglibc=!glibc
MULTILIB_OSDIRNAMES += muclibc/mfp32=!uclibc/fp32
MULTILIB_OSDIRNAMES += msoft-float=!uclibc/soft-float
MULTILIB_OSDIRNAMES += muclibc/msoft-float=!uclibc/soft-float
MULTILIB_OSDIRNAMES += mfp32=!uclibc/fp32
MULTILIB_OSDIRNAMES += mglibc/mfp32=!glibc/fp32
MULTILIB_OSDIRNAMES += mglibc/msoft-float=!glibc/soft-float
